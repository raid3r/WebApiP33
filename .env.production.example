# Copy this file to .env on the production host and replace all example values

# Required secrets
DB_PASSWORD=ChangeMe-Use-A-Strong-SQL-Password-123!
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Published frontend host ports for docker-compose.production.yml
FRONTEND_EXTERNAL_PORT=80
FRONTEND_HTTPS_EXTERNAL_PORT=443

# Domain / HTTPS settings used by vue-front/nginx.conf.template
APP_DOMAIN=example.com
APP_DOMAIN_WWW=www.example.com
SSL_CERTS_DIR=./deploy/certs
SSL_CERT_FULLCHAIN_PATH=/etc/nginx/ssl/fullchain.pem
SSL_CERT_PRIVKEY_PATH=/etc/nginx/ssl/privkey.pem

