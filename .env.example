# Copy this file to .env and fill in your own values before running docker compose

# SQL Server SA password (min 8 chars, mix of upper/lower/digit/symbol)
DB_PASSWORD=StrongPassword123!

# JWT signing secret – use a long random string in production (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-me-before-deploying

# Published host ports for Docker services
DB_EXTERNAL_PORT=1433
API_EXTERNAL_PORT=8082
FRONTEND_EXTERNAL_PORT=8081

# Production domain / HTTPS placeholders (currently unused until commented config is enabled)
# APP_DOMAIN=example.com
# APP_DOMAIN_WWW=www.example.com
# FRONTEND_HTTPS_EXTERNAL_PORT=8443
# SSL_CERTS_DIR=./deploy/certs
# SSL_CERT_FULLCHAIN_PATH=/etc/nginx/ssl/fullchain.pem
# SSL_CERT_PRIVKEY_PATH=/etc/nginx/ssl/privkey.pem

