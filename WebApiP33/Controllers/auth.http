@WebApiP33_HostAddress = https://localhost:7025

### Register a new user
POST {{WebApiP33_HostAddress}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "test1@test.com",
  "password": "1111"
}


### Login with the registered user
POST {{WebApiP33_HostAddress}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "test1@test.com",
  "password": "1111"
}


### get profile of the logged in user
@token=eyJhbGciOiJodHRwOi8vd3d3LnczLm9yZy8yMDAxLzA0L3htbGRzaWctbW9yZSNobWFjLXNoYTI1NiIsInR5cCI6IkpXVCJ9..O7bLgtkmI4Hh2U4RMCb-x3GHAi9XaT2BW3lLxzO1xU0

###

GET {{WebApiP33_HostAddress}}/api/v1/profile
Authorization: Bearer {{token}}
Accept: application/json


